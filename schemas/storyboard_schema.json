{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Storyboard",
  "type": "object",
  "properties": {
    "script_metadata": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "total_duration": { "type": "number", "minimum": 1, "maximum": 60 },
        "aspect_ratio": { "type": "string", "enum": ["9:16", "16:9", "1:1"] },
        "style": { "type": "string" }
      },
      "required": ["total_duration", "aspect_ratio"]
    },
    "shots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "shot_id": { "type": "integer" },
          "duration": { "type": "number", "minimum": 0.5 },
          "story_beat": { "type": "string" },
          "visual_desc": { "type": "string" },
          "shot_size": { 
            "type": "string", 
            "enum": ["Extreme Close-up", "Close-up", "Medium Shot", "Full Shot", "Long Shot"] 
          },
          "camera_motion": { "type": "string" },
          "dialogue": { "type": "string" },
          "must_include": { 
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["shot_id", "duration", "visual_desc", "shot_size"]
      }
    }
  },
  "required": ["script_metadata", "shots"]
}
